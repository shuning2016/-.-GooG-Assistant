{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/cron.py":    { "maxDuration": 300 },
    "api/trigger.py": { "maxDuration": 300 },
    "api/view.py":    { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/view" }
  ]
}
