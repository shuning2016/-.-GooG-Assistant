# ─── Google OAuth2 ────────────────────────────────────────────
# Obtain from Google Cloud Console → OAuth2 credentials (Desktop app)
# Then run: python setup_google_token.py
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Upstash Redis (free at upstash.com) ─────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Email delivery (choose one) ─────────────────────────────
# Option A: SendGrid (recommended — free tier supports 100 emails/day)
SENDGRID_API_KEY=SG.your_sendgrid_key_here
FROM_EMAIL=daily-brief@yourdomain.com

# Option B: SMTP fallback (e.g. Gmail app password, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password

# ─── Security ─────────────────────────────────────────────────
# Vercel automatically passes this when calling your cron endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=your_random_secret_here

# Token for the manual /api/trigger?token= endpoint (bookmark this URL).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TRIGGER_SECRET=your_random_trigger_secret_here

# ─── App URL (set automatically by Vercel in production) ──────
# Only needed for local testing. In production Vercel sets VERCEL_URL.
# VERCEL_URL=your-app.vercel.app
